# 高德地图API Key（必需）
# 请在 https://console.amap.com/dev/key/app 申请
AMAP_KEY=your_api_key_here

# API请求超时时间（毫秒，可选，默认10000）
# AMAP_TIMEOUT=10000

# Dashboard服务端口（可选，默认8080）
# DASHBOARD_PORT=8080

# Dashboard服务主机（可选，默认localhost）
# DASHBOARD_HOST=localhost

# ============================================
# 可观测性配置
# ============================================

# 可观测性数据保存目录（可选，默认./observability-data）
# OBSERVABILITY_DATA_DIR=./observability-data

# 数据保留天数（可选，默认30天）
# OBSERVABILITY_RETENTION_DAYS=30

# 自动保存间隔（毫秒，可选，默认60000=1分钟）
# OBSERVABILITY_SAVE_INTERVAL=60000

# 调试模式（开启后显示API调用详情）
# DEBUG_AMAP=true
